# ===========================
# AWS Configuration
# ===========================
aws_region        = "us-east-1"
availability_zone = "us-east-1a"

# ===========================
# Project Configuration
# ===========================
project_name = "velure"
environment  = "production"

# ===========================
# VPC Configuration
# ===========================
vpc_cidr           = "10.0.0.0/16"
public_subnet_cidr = "10.0.1.0/24"
private_subnet_cidr = "10.0.10.0/24"

# Secondary subnets in a 2nd AZ. Required for ALB (public) and RDS subnet group (private).
# Each CIDR must be unique — do NOT reuse the public secondary range below.
availability_zone_secondary   = "us-east-1b"
public_subnet_secondary_cidr  = "10.0.11.0/24"
private_subnet_secondary_cidr = "10.0.12.0/24"

# ===========================
# EKS Configuration
# ===========================
eks_cluster_version = "1.29"

# Node Group Configuration
# NOTE: t3.small is the MINIMUM for EKS — t3.micro is not supported.
node_instance_type = "t3.small"
node_disk_size     = 20

# Scaling
node_min_size     = 1
node_desired_size = 2
node_max_size     = 2

# NOTE: capacity type is hardcoded to ON_DEMAND in modules/eks/main.tf.
# To use Spot, change capacity_type there (no tfvars knob exists yet).

# ===========================
# RDS Configuration (shared between Auth and Orders)
# ===========================
rds_instance_class    = "db.t4g.micro"  # Free Tier
rds_allocated_storage = 20              # Free Tier: 20GB
rds_engine_version    = "17.4"          # PostgreSQL 17.4

# ===========================
# RDS Auth Service
# ===========================
rds_auth_db_name   = "velure_auth"
rds_auth_username  = "velure_admin"

# 🔐 IMPORTANT: change this password!
# Use a password manager to generate a strong one.
# Example: openssl rand -base64 32
rds_auth_password = "CHANGE_ME_AUTH_PASSWORD_HERE"

# ===========================
# RDS Orders Service
# (shared between publish-order and process-order)
# ===========================
rds_orders_db_name   = "velure_orders"
rds_orders_username  = "velure_admin"

# 🔐 IMPORTANT: change this password!
rds_orders_password = "CHANGE_ME_ORDERS_PASSWORD_HERE"

# ===========================
# Amazon MQ (RabbitMQ) Configuration
# ===========================
amazonmq_instance_type   = "mq.t3.micro"      # Cost: ~$60-70/month
amazonmq_deployment_mode = "SINGLE_INSTANCE"  # For production: ACTIVE_STANDBY_MULTI_AZ

rabbitmq_admin_username = "admin"

# 🔐 IMPORTANT: change this password!
rabbitmq_admin_password = "CHANGE_ME_RABBITMQ_PASSWORD_HERE"

# ===========================
# JWT Secrets (REQUIRED — no defaults)
# ===========================
# 🔐 Generate with: openssl rand -base64 48
jwt_secret         = "CHANGE_ME_JWT_SECRET_HERE"
jwt_refresh_secret = "CHANGE_ME_JWT_REFRESH_SECRET_HERE"

# ===========================
# MongoDB Atlas (REQUIRED — no default)
# ===========================
mongodb_connection_string = "mongodb+srv://USER:PASS@cluster.mongodb.net/product_service?retryWrites=true&w=majority"

# ===========================
# Domain (Route53)
# ===========================
domain_name = "velure.app.br"

# ===========================
# Common Tags
# ===========================
# All tags are applied to every resource.
# Useful for cost tracking and organization.
tags = {
  Project     = "velure"
  Environment = "production"
  ManagedBy   = "terraform"
  Owner       = "your-name-here"
  CostCenter  = "personal-project"
}

# ===========================
# Notes
# ===========================
#
# 1. COSTS:
#    - EKS Cluster: $72/month
#    - 2x t3.small: ~$30/month
#    - 1x NAT Gateway: ~$32/month + data transfer
#    - RDS Free Tier: $0 (first year, 750h/month)
#    - Total: ~$140-150/month
#
# 2. RDS FREE TIER:
#    - db.t4g.micro: 750h/month (enough for one instance 24/7)
#    - 20GB storage
#    - With two instances, only one will fall under the free tier.
#
# 3. AZ LAYOUT:
#    - Subnets span 2 AZs (required by ALB + RDS subnet group),
#      but workloads/NAT/RDS instance run in a single AZ to cut cost.
#    - Single NAT Gateway saves ~$32/month vs one-per-AZ.
#    - Not full multi-AZ HA — fine for a learning project, not real prod.
#
# 4. SECURITY:
#    - Never commit this file with real passwords.
#    - Use a password manager.
#    - Consider AWS Secrets Manager + External Secrets Operator.
#
# 5. MONGODB:
#    - We assume MongoDB is hosted on Atlas.
#    - DocumentDB is not included, to keep costs down.
#
# 6. REDIS:
#    - Deployed in-cluster via Helm.
#    - ElastiCache is not used, to keep costs down.
#
# 7. RABBITMQ:
#    - Amazon MQ (managed RabbitMQ): ~$60-70/month (mq.t3.micro)
#    - More reliable than RabbitMQ in-cluster.
#    - No maintenance or troubleshooting required.
