{
	email admin@velure.local

	local_certs

	auto_https disable_redirects

	log {
		output file /var/log/caddy/access.log {
			roll_size 100mb
			roll_keep 5
		}
		format json
		level INFO
	}
}

velure.local {
	log {
		output file /var/log/caddy/velure.log {
			roll_size 50mb
			roll_keep 3
		}
		format json
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"

		Permissions-Policy "geolocation=(), microphone=(), camera=()"

		Content-Security-Policy "default-src 'self' 'unsafe-inline' 'unsafe-eval' https: data: blob:; img-src 'self' https: data: blob: unsplash.com *.unsplash.com;"
		-Server
		-X-Powered-By
	}

	@options {
		method OPTIONS
	}
	handle @options {
		header Access-Control-Allow-Origin "*"
		header Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
		header Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With"
		header Access-Control-Max-Age "3600"
		respond 204
	}

	handle /health {
		header Content-Type "application/json"
		respond `{"status":"healthy","timestamp":"{time.now.unix}","proxy":"caddy v2.8","services":{"auth":"/api/users","product":"/api/products","orders":"/api/orders"}}` 200
	}

	@auth_routes path /api/sessions /api/sessions/* /api/users /api/users/* /api/tokens /api/tokens/*
	handle @auth_routes {
		reverse_proxy auth-service:3020 {
			health_uri /health
			health_interval 10s
			health_timeout 5s
			health_status 2xx
			header_up X-Real-IP {remote_host}
			header_down Access-Control-Allow-Origin "*"
			header_down Access-Control-Allow-Credentials "true"
			transport http {
				dial_timeout 10s
				response_header_timeout 60s
				read_timeout 60s
				write_timeout 60s
			}
		}
	}

	@product_routes path /api/products /api/products/*
	handle @product_routes {
		reverse_proxy product-service:3010 {
			health_uri /health
			health_interval 10s
			health_timeout 5s
			health_status 2xx
			header_up X-Real-IP {remote_host}
			header_down Access-Control-Allow-Origin "*"
			header_down Access-Control-Allow-Credentials "true"
			header_down Cache-Control "public, max-age=300"
		}
	}

	@order_routes path /api/orders /api/orders/* /api/me/*
	handle @order_routes {
		reverse_proxy publish-order-service:3030 {
			health_uri /health
			health_interval 10s
			health_timeout 5s
			health_status 2xx
			flush_interval -1
			header_up X-Real-IP {remote_host}
			header_down Access-Control-Allow-Origin "*"
			header_down Access-Control-Allow-Credentials "true"
			header_down Cache-Control "no-cache"
			header_down X-Accel-Buffering "no"
			transport http {
				dial_timeout 10s
				read_timeout 7200s
				write_timeout 7200s
			}
		}
	}

	handle /* {
		reverse_proxy ui-service:8080 {
			health_uri /health
			health_interval 30s
			health_timeout 5s
			health_status 2xx

			header_up X-Real-IP {remote_host}
		}
	}

	encode gzip zstd

	handle_errors {
		@5xx expression `{http.error.status_code} >= 500`
		handle @5xx {
			header Content-Type "application/json"
			respond `{"error":"Erro interno do servidor","message":"Por favor, tente novamente mais tarde","status":{http.error.status_code}}` {http.error.status_code}
		}

		@4xx expression `{http.error.status_code} >= 400 && {http.error.status_code} < 500`
		handle @4xx {
			header Content-Type "application/json"
			respond `{"error":"Requisição inválida","message":"Verifique os dados e tente novamente","status":{http.error.status_code}}` {http.error.status_code}
		}
	}
}
